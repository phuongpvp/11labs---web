# ==============================================================
# CHẾ ĐỘ BẢO TRÌ (Bật khi chuyển Server)
# Bỏ dấu # ở 4 dòng dưới đây để BẬT chế độ bảo trì.
# Thay 123.456.789.000 bằng IP thật của máy bạn (nếu muốn vào được web).
# ==============================================================
# RewriteEngine On
# RewriteCond %{HTTP:CF-Connecting-IP} !14\.226\.24\.242
# RewriteCond %{HTTP:X-Forwarded-For} !14\.226\.24\.242
# RewriteCond %{REMOTE_ADDR} !14\.226\.24\.242
# RewriteCond %{REQUEST_URI} !^/maintenance\.html$
# RewriteCond %{REQUEST_URI} !^/api/ [NC]
# RewriteRule ^(.*)$ /maintenance.html [R=302,L]


# Clean URLs - Bỏ đuôi .html
RewriteEngine On

# Không rewrite file thực tế hoặc thư mục
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Thêm .html nếu file tồn tại
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)$ $1.html [L]
